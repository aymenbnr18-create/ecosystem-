<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>إيكو إنوفيت - تطبيق التدوير الحقيقي</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f7f6;
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .app-container {
            max-width: 400px;
            width: 100%;
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            padding: 25px;
            box-sizing: border-box;
        }
        h2 { color: #2e7d32; text-align: center; }
        .card {
            background: #e8f5e9;
            border-radius: 15px;
            padding: 20px;
            text-align: center;
            margin-bottom: 20px;
        }
        .points { font-size: 32px; font-weight: bold; color: #1b5e20; }
        input, button {
            width: 100%;
            padding: 12px;
            margin: 10px 0;
            border-radius: 10px;
            border: 1px solid #ccc;
            box-sizing: border-box;
        }
        button {
            background-color: #4caf50;
            color: white;
            border: none;
            font-weight: bold;
            cursor: pointer;
        }
        button:hover { background-color: #43a047; }
        .hidden { display: none; }
    </style>
</head>
<body>

<div class="app-container">
    <!-- شاشة تسجيل الدخول وإنشاء الحساب -->
    <div id="login-screen">
        <h2>تسجيل الدخول | إيكو إنوفيت</h2>
        <input type="email" id="email" placeholder="البريد الإلكتروني">
        <input type="password" id="password" placeholder="كلمة المرور">
        <button onclick="loginUser()">دخول الحساب</button>
        <button onclick="registerUser()" style="background-color: #2196F3; margin-top: 5px;">إنشاء حساب جديد</button>
    </div>

    <!-- لوحة تحكم المستخدم بعد الدخول -->
    <div id="dashboard-screen" class="hidden">
        <h2>مرحبًا بك في إيكو إنوفيت 🌱</h2>
        <p id="user-email-display" style="text-align: center; color: #666;"></p>
        <div class="card">
            <p>رصيد نقاطك البيئية الحالي</p>
            <div class="points" id="user-points">0</div>
        </div>
        
        <h3>تسجيل عملية تدوير جديدة</h3>
        <input type="number" id="weight" placeholder="وزن النفايات بالـ كجم (بلاستيك/ورق)">
        <button onclick="addPoints()">إرسال وكسب نقاط</button>
        <button onclick="logoutUser()" style="background-color: #e53935; margin-top: 20px;">تسجيل الخروج</button>
    </div>
</div>

<!-- استدعاء مكتبات Firebase الأساسية من السيرفر مباشرة لتوافق واجهات الويب التقليدية -->
<script src="https://gstatic.com"></script>
<script src="https://gstatic.com"></script>
<script src="https://gstatic.com"></script>

<script>
    // كود الإعدادات الخاص بمشروعك (المأخوذ من صورتك)
    const firebaseConfig = {
        apiKey: "AIzaSyBsmt-eq2HTM5doBq031DZGPmkv-iuH1KI",
        authDomain: "://firebaseapp.com",
        projectId: "ecosystem-c3cc4",
        storageBucket: "ecosystem-c3cc4.firebasestorage.app",
        messagingSenderId: "590924866474",
        appId: "1:590924866474:web:c2204300eb0317672641d3"
    };

    // تفعيل Firebase داخل التطبيق
    firebase.initializeApp(firebaseConfig);
    const auth = firebase.auth();
    const db = firebase.firestore();

    let currentUserDocRef = null;

    // مراقبة حالة المستخدم (هل هو مسجل دخول أم لا؟)
    auth.onAuthStateChanged(user => {
        if (user) {
            document.getElementById('login-screen').classList.add('hidden');
            document.getElementById('dashboard-screen').classList.remove('hidden');
            document.getElementById('user-email-display').innerText = user.email;
            
            // ربط حساب المستخدم بجدول النقاط في قاعدة البيانات
            currentUserDocRef = db.collection("users").doc(user.uid);
            
            // جلب النقاط الحقيقية من السيرفر وعرضها فوراً
            currentUserDocRef.onSnapshot(doc => {
                if (doc.exists) {
                    document.getElementById('user-points').innerText = doc.data().points || 0;
                } else {
                    currentUserDocRef.set({ points: 0 });
                }
            });
        } else {
            document.getElementById('dashboard-screen').classList.add('hidden');
            document.getElementById('login-screen').classList.remove('hidden');
        }
    });

    // وظيفة إنشاء حساب جديد وحفظه في السيرفر
    function registerUser() {
        const email = document.getElementById('email').value;
        const password = document.getElementById('password').value;
        if(!email || !password) return alert('برجاء ملء البيانات أولاً');

        auth.createUserWithEmailAndPassword(email, password)
            .then(cred => {
                return db.collection("users").doc(cred.user.uid).set({ points: 0 });
            })
            .then(() => alert('تم إنشاء الحساب بنجاح ودخولك الآن!'))
            .catch(err => alert('خطأ في إنشاء الحساب: ' + err.message));
    }

    // وظيفة تسجيل الدخول للحسابات الموجودة مسبقاً
    function loginUser() {
        const email = document.getElementById('email').value;
        const password = document.getElementById('password').value;
        if(!email || !password) return alert('برجاء ملء البيانات أولاً');

        auth.signInWithEmailAndPassword(email, password)
            .catch(err => alert('خطأ في تسجيل الدخول: ' + err.message));
    }

    // وظيفة إضافة النقاط وتحديثها تلقائياً على قاعدة البيانات السحابية
    function addPoints() {
        const weight = parseFloat(document.getElementById('weight').value);
        if(weight > 0 && currentUserDocRef) {
            const addedPoints = weight * 10; // 10 نقاط لكل كيلو
            
            currentUserDocRef.update({
                points: firebase.firestore.FieldValue.increment(addedPoints)
            }).then(() => {
                alert(`ممتاز! تم إضافة ${addedPoints} نقطة إلى حسابك على السيرفر.`);
                document.getElementById('weight').value = '';
            }).catch(err => alert('حدث خطأ أثناء تحديث النقاط: ' + err.message));
        } else {
            alert('الرجاء إدخال وزن صحيح');
        }
    }

    // وظيفة تسجيل الخروج
    function logoutUser() {
        auth.signOut();
    }
</script>

</body>
</html>



